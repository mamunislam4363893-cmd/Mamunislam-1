# TELEGRAM_BOT_TOKEN: Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# BOT_USERNAME: Your bot's username (without @)
BOT_USERNAME=

# ADMIN_ID: Your Telegram user ID for admin notifications
ADMIN_ID=

# ADMIN_PASSWORD: Password for the admin panel
ADMIN_PASSWORD=admin123

# APP_URL: The URL where this applet is hosted (auto-injected)
APP_URL=

# SMTPLABS_API_KEY: Optional API key for SmtpLabs integration
SMTPLABS_API_KEY=

# GEMINI_API_KEY: Required for Gemini AI API calls (auto-injected)
GEMINI_API_KEY=
